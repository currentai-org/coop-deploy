# Coop stack environment for the v6 Coop-first deployment (local DBs, containerized).
# Curated from _repos/coop/.env.docker — kept HERE so the deploy space is
# self-contained and portable to cloud prod (swap hosts/secrets, keep the shape).
# Review/replace every secret before any non-local deployment.

# ── Postgres ──────────────────────────────────────────────────────────
DATABASE_HOST=postgres
DATABASE_READ_ONLY_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres123

API_SERVER_DATABASE_HOST=postgres
API_SERVER_DATABASE_READ_ONLY_HOST=postgres
API_SERVER_DATABASE_PORT=5432
API_SERVER_DATABASE_NAME=postgres
API_SERVER_DATABASE_USER=postgres
API_SERVER_DATABASE_PASSWORD=postgres123

# ── Session ───────────────────────────────────────────────────────────
SESSION_SECRET=overwritten_by_github_actions
COOP_ADMIN_EMAIL=overwritten_by_github_actions
COOP_ADMIN_PASSWORD=overwritten_by_github_actions
GRAPHQL_OPAQUE_SCALAR_SECRET=overwritten_by_github_actions

# ── ClickHouse ────────────────────────────────────────────────────────
# Present because the published coop-migrations/coop-server images expect it.
# NOT used by the /content sync rules path (warehouse/analytics only).
CLICKHOUSE_PROTOCOL=http
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_DATABASE=analytics
CLICKHOUSE_MIGRATIONS_TABLE=MIGRATIONS_METADATA

# ── ScyllaDB ──────────────────────────────────────────────────────────
# Present because the published images expect it (item-submission history).
# NOT used by the /content sync rules path.
SCYLLA_USERNAME=cassandra
SCYLLA_PASSWORD=cassandra
SCYLLA_HOSTS='scylla'
SCYLLA_LOCAL_DATACENTER='datacenter1'
SCYLLA_KEYSPACE='item_investigation_service'
SCYLLA_REPLICATION_CLASS='SimpleStrategy'
SCYLLA_REPLICATION_FACTOR='1'
SCYLLA_COMPACTION_STRATEGY='SizeTieredCompactionStrategy'
SCYLLA_HAS_ENTERPRISE_FEATURES='false'

# ── GraphQL / Server ──────────────────────────────────────────────────
GRAPHQL_MAX_DEPTH=10
EXPOSE_SENSITIVE_IMPLEMENTATION_DETAILS_IN_ERRORS=false
DATABASE_PRINT_LOGS=false


# NOTE (corrected per codex review): the chat-block CUSTOM_ACTION callbackUrl we use
# is http://audit-sink:9090 — a Docker Compose SERVICE DNS name, which Coop reaches
# regardless of this flag (the custom-action create path does not SSRF-validate the
# callbackUrl). This flag only affects validation of literal `localhost`/`127.0.0.1`
# URLs elsewhere; we set it true only so a callback pointed at localhost would also
# work in local dev. Keep false in cloud prod unless intentionally allowing local URIs.
ALLOW_USER_INPUT_LOCALHOST_URIS=true

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_USE_CLUSTER=false
REDIS_HOST=redis
REDIS_PORT=6379

# ── Observability ─────────────────────────────────────────────────────
OTEL_SERVICE_NAME=coop

# ── General ───────────────────────────────────────────────────────────
# Process items inline (not via the async queue) so /content sync rules run in-request.
ITEM_QUEUE_TRAFFIC_PERCENTAGE='0'
UI_URL=http://coop.publicai.co
# (No INTEGRATIONS_CONFIG_PATH: vanilla Coop ships no custom plugin. The stock server
# tolerates its absence; we removed it rather than point at a file we no longer ship.)